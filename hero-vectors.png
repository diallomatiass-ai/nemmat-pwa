@media (max-width: 991px) {
    .demo-marketplace .style-marketplace.filter-course .lp-form-course-filter .course-filter-submit {
        margin: 0;
    }
}
.thim-header-info > li svg {
		width: max-content;
}
.learnpress-question img {
    width: 100%; /* Adjust to specific width if needed */
    max-width: 500px; /* Prevent the image from getting too large */
    height: auto; /* Maintain aspect ratio */
}


.elementor-element-ae6abd0 ul.thim-social-media li a i {
    color: #fff !important;
}

footer#colophon .footer a {
    color: #fff !important;
}

#tab .tab-item {
    margin: 10px 0px 0px 0px;
    padding: 0px 40px 0px 0px;
    color: #346cf1;
    background-color: #02010100;
    font-family: poppins;
    font-size: 28px;
    font-weight: 600;
    text-transform: var(--e-global-typography-a539aa8-text-transform);
    line-height: var(--e-global-typography-a539aa8-line-height);
    letter-spacing: var(--e-global-typography-a539aa8-letter-spacing);
    word-spacing: var(--e-global-typography-a539aa8-word-spacing);
}
